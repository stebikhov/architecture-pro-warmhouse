@startuml diagram
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Device Management Service - Component Diagram (C4 Level 3)

Container_Boundary(device_mgmt, "Device Management Service") {
    Container(device_api, "Device API", "Gin", "REST endpoints для управления устройствами")
    
    Container(device_service, "Device Service", "Business Logic", "Бизнес логика и webhook-уведомления")
    ContainerDb(device_repository, "Device Repository", "Data Access Layer", "CRUD операции с устройствами")
    
    ContainerDb(device_db, "Device DB", "PostgreSQL", "Хранение конфигурации устройств")
}

System_Ext(telemetry_svc, "Telemetry Service", "Получение webhook-уведомлений о событиях устройств")

Rel(device_api, device_service, "Делегирует запросы")
Rel(device_service, device_repository, "Использует")
Rel(device_repository, device_db, "Чтение/запись", "PostgreSQL Protocol")

Rel(device_service, telemetry_svc, "Отправляет webhook при создании/обновлении/удалении устройства", "HTTP POST")

@enduml
