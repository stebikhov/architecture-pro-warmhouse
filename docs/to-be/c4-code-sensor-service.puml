@startuml
title Sensor Service - Class Diagram

enum SensorType {
    temperature
}

class Sensor {
    +ID: int
    +Name: string
    +Type: SensorType
    +Location: string
    +Value: float64
    +Unit: string
    +Status: string
    +LastUpdated: time.Time
    +CreatedAt: time.Time
}

class SensorCreate {
    +Name: string
    +Type: SensorType
    +Location: string
    +Unit: string
}

class SensorUpdate {
    +Name?: string
    +Type?: SensorType
    +Location?: string
    +Value?: float64
    +Unit?: string
    +Status?: string
}

class SensorHandler {
    <<Handler>>
    // HTTP request handling for sensor endpoints
}

class TemperatureService {
    <<Service>>
    // HTTP client for external temperature API
}

class DB {
    <<Repository>>
    // PostgreSQL access via pgxpool
}

Sensor "1" -- "0..*" SensorType : has
SensorHandler --> DB : uses
SensorHandler --> TemperatureService : uses
DB ..> Sensor : maps to/from
SensorHandler ..> SensorCreate : binds from JSON
SensorHandler ..> SensorUpdate : binds from JSON

@enduml
