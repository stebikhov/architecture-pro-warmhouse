@startuml diagram
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_WITH_LEGEND()

title Temperature Monitoring Service - Component Diagram (C4 Level 3)

Container_Boundary(temp_monitoring, "Temperature Monitoring Service") {
    Container(temp_api, "Temperature API", "Express.js", "REST API для получения данных о температуре")
    
    Container(api_handler, "API Handler", "Request Handler", "Обработка входящих HTTP запросов")
    Container(cache_manager, "Cache Manager", "Redis Cache", "Кэширование данных температуры")
    Container(external_api_client, "External API Client", "HTTP Client", "Взаимодействие с внешним Temperature API")
    Container(data_transformer, "Data Transformer", "Data Mapper", "Трансформация и нормализация данных")
    
    ContainerDb(temp_repo, "Temperature Repository", "Data Access Layer", "CRUD операции с данными температуры")
    Container(event_producer, "Event Producer", "AMQP Publisher", "Публикация событий температуры")
    
    ContainerQueue(message_broker, "Message Broker", "RabbitMQ", "Асинхронная коммуникация")
}

System_Ext(external_temp_api, "External Temperature API", "Внешний сервис", "Данные о температуре")
System_Ext(telemetry_svc, "Telemetry Service", "Поставщик данных телеметрии")

Rel(temp_api, api_handler, "Обрабатывает запросы")
Rel(api_handler, cache_manager, "Проверяет кэш")
Rel(api_handler, external_api_client, "Запрашивает данные")
Rel(external_api_client, external_temp_api, "HTTP GET", "REST API")
Rel(external_api_client, data_transformer, "Трансформирует ответ")
Rel(data_transformer, temp_repo, "Сохраняет данные")
Rel(data_transformer, event_producer, "Генерирует события")
Rel(event_producer, message_broker, "Публикует", "AMQP")

Rel(telemetry_svc, temp_api, "Запрашивает данные", "gRPC")
Rel(cache_manager, telemetry_svc, "Синхронизирует кэш", "gRPC")

@enduml
